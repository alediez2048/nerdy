{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://YOUR-RAILWAY-URL.up.railway.app/:path*" },
    { "source": "/health", "destination": "https://YOUR-RAILWAY-URL.up.railway.app/health" },
    { "source": "/images/:path*", "destination": "https://YOUR-RAILWAY-URL.up.railway.app/images/:path*" },
    { "source": "/videos/:path*", "destination": "https://YOUR-RAILWAY-URL.up.railway.app/videos/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
