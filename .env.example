# Ad-Ops-Autopilot — Environment variables
# Copy to .env and fill in your values

# Required: Google AI (Gemini) API key
# Get one at https://ai.google.dev/
GEMINI_API_KEY=

# Optional: Override global seed for reproducibility
# GLOBAL_SEED=my_reproducible_seed

# Database (Docker default — override for external DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nerdy

# Redis (Docker default — override for external Redis)
REDIS_URL=redis://localhost:6379/0

# Auth — Clerk JWT validation (PG-01)
# JWKS endpoint for your Clerk instance
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
# JWT issuer — must match your Clerk domain
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
# Set to true for local dev (skips JWT validation, uses X-User-Id header)
DEV_MODE=false

# Auth — legacy (kept for backward compat)
GOOGLE_CLIENT_ID=
SECRET_KEY=change-me-to-a-random-string

# Video generation provider (fal, veo, kling — default: fal)
# VIDEO_PROVIDER=fal

# Fal.ai API key (required when VIDEO_PROVIDER=fal)
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=
# Optional alias if your tooling uses a different name:
# FAL_AI_KEY=

# Kling AI (required when VIDEO_PROVIDER=kling)
KLING_API_KEY=
