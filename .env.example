# Ad-Ops-Autopilot — Environment variables
# Copy to .env and fill in your values

# Required: Google AI (Gemini) API key
# Get one at https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override global seed for reproducibility
# If not set, uses a default from config
# GLOBAL_SEED=my_reproducible_seed
